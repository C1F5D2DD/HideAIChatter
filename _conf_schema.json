{
  "max_width": {
    "description": "图片最大宽度（像素）",
    "type": "int",
    "hint": "建议范围：300-1000，宽度过小将导致文字频繁换行",
    "default": 500
  },
  "font_size": {
    "description": "文字字号（像素）",
    "type": "int",
    "hint": "建议范围：16-48，过大会超出图片宽度",
    "default": 36
  },
  "bg_color": {
    "description": "图片背景色",
    "type": "string",
    "hint": "支持颜色名（如white）或十六进制（如#f8f8f8）",
    "default": "white"
  },
  "text_color": {
    "description": "文字颜色",
    "type": "string",
    "hint": "支持颜色名（如black）或十六进制（如#333333）",
    "default": "black"
  },
  "font_path": {
    "description": "字体文件绝对路径",
    "type": "string",
    "default": "/usr/share/fonts/truetype/noto/NotoSansCJK-Regular.ttc"
  },
  "output_path": {
    "description": "图片输出路径,放在可以用Image.fromURL得到的路径下",
    "type": "string",
    "default": "/var/www/html/tmp/hider.png"
  },
  "image_format": {
    "description": "图片格式",
    "type": "string",
    "hint": "仅支持PNG/JPG格式",
    "options": ["png", "jpg"],
    "default": "png"
  },
  "no_think": {
    "description": "是否强制阻止思考",
    "type": "bool",

    "options": [true, false],
    "default": true
  }
}